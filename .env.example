# TezAtlas Multi-Agent System — API Keys
# Copy this file to .env and fill in the keys you'll use.
# Only the providers you configure in agents.yaml need keys.

# OpenAI
OPENAI_API_KEY=

# Google Gemini (via OpenAI-compatible endpoint)
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Anthropic (uses separate SDK, not OpenAI-compatible)
ANTHROPIC_API_KEY=

# Grok (xAI)
GROK_API_KEY=

# Groq
GROQ_API_KEY=

# Together AI
TOGETHER_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# Custom provider (add your own):
# CUSTOM_PROVIDER_API_KEY=
# CUSTOM_PROVIDER_BASE_URL=
# CUSTOM_PROVIDER_MODEL=
